{
  "name": "atomberg-goal-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "dev:api": "pnpm --filter @atomberg/api run dev",
    "dev:web": "pnpm --filter @atomberg/web run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @atomberg/database run generate",
    "db:push": "pnpm --filter @atomberg/database run push",
    "db:seed": "pnpm --filter @atomberg/database run seed",
    "db:studio": "pnpm --filter @atomberg/database run studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt"
    ]
  }
}
