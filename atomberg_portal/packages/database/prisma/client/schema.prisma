generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  departmentId String
  managerId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  department   Department    @relation(fields: [departmentId], references: [id])
  manager      User?         @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates User[]        @relation("ManagerRelation")
  goals        Goal[]
  auditLogs    AuditLog[]
  chatMessages ChatMessage[]
  escalations  Escalation[]
}

model Department {
  id                String @id @default(uuid())
  name              String @unique
  thrustArea        String
  categoryLifecycle String @default("MATURE")
  users             User[]
}

model GoalCycle {
  id        String    @id @default(uuid())
  name      String
  phase     String
  status    String    @default("ACTIVE")
  startDate DateTime
  endDate   DateTime
  goals     Goal[]
  checkIns  CheckIn[]
}

model Goal {
  id           String     @id @default(uuid())
  cycleId      String?
  employeeId   String
  title        String
  description  String?
  thrustArea   String
  uomType      UoMType
  targetValue  Decimal    @default(0) @db.Decimal(10, 2)
  actualValue  Decimal    @default(0) @db.Decimal(10, 2)
  weightage    Int
  status       GoalStatus @default(NOT_STARTED)
  categoryType String     @default("RND")
  channelType  String?
  isShared     Boolean    @default(false)
  parentGoalId String?
  lockedAt     DateTime?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employee  User       @relation(fields: [employeeId], references: [id])
  cycle     GoalCycle? @relation(fields: [cycleId], references: [id])
  checkIns  CheckIn[]
  auditLogs AuditLog[]
}

model CheckIn {
  id             String        @id @default(uuid())
  goalId         String
  cycleId        String?
  quarter        String
  plannedValue   Decimal       @default(0) @db.Decimal(10, 2)
  actualValue    Decimal       @default(0) @db.Decimal(10, 2)
  status         CheckInStatus @default(NOT_STARTED)
  managerComment String?
  computedScore  Decimal       @default(0) @db.Decimal(10, 4)
  checkInDate    DateTime      @default(now())

  goal  Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  cycle GoalCycle? @relation(fields: [cycleId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  goalId     String
  changedBy  String
  fieldName  String
  oldValue   String?
  newValue   String?
  actionType String
  ipAddress  String?
  changedAt  DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id])
  user User @relation(fields: [changedBy], references: [id])
}

model Escalation {
  id              String    @id @default(uuid())
  triggerType     String
  triggeredForId  String
  escalationLevel Int       @default(1)
  message         String
  isResolved      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  user User @relation(fields: [triggeredForId], references: [id])
}

model ChatMessage {
  id         String   @id @default(uuid())
  userId     String
  role       String
  content    String
  intentType String?
  metadata   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DbConnection {
  id         String   @id @default(uuid())
  name       String   @default("Atomberg Legacy DB")
  dbType     String   @default("postgresql")
  host       String
  port       Int      @default(5432)
  database   String
  username   String
  isActive   Boolean  @default(true)
  isReadOnly Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ManufacturingDaily {
  id            String   @id @default(uuid())
  date          DateTime @db.Date
  lineId        Int
  unitsProduced Int
  rejectionRate Decimal  @db.Decimal(6, 4)
  energyKwh     Decimal  @db.Decimal(10, 2)

  @@index([date, lineId])
  @@map("manufacturing_daily")
}

model SalesMonthly {
  id        String   @id @default(uuid())
  month     DateTime @db.Date
  channel   String
  revenue   Decimal  @db.Decimal(14, 2)
  unitsSold Int
  region    String

  @@index([month, channel])
  @@map("sales_monthly")
}

model LegacyEmployee {
  id         String  @id @default(uuid())
  name       String
  department String
  managerId  String?
  role       String

  goals LegacyGoal[]

  @@map("legacy_employees")
}

model LegacyGoal {
  id         String  @id @default(uuid())
  employeeId String
  title      String
  target     Decimal @db.Decimal(10, 2)
  actual     Decimal @db.Decimal(10, 2)
  quarter    String

  employee LegacyEmployee @relation(fields: [employeeId], references: [id])

  @@map("legacy_goals")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UoMType {
  MIN
  MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
  PENDING
}

enum CheckInStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}
